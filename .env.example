APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://nbx.naraboxtv.com
TRUSTED_PROXIES=*
CDN_ADMIN_EMAIL=smoggrafton@gmail.com
CDN_ADMIN_PASSWORD=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CDN_APP_URL=https://nbx.naraboxtv.com
CDN_DEFAULT_IMPORT_MODE=queue
CDN_IMPORT_QUEUE=default
CDN_OPTIMIZATION_QUEUE=optimization
CDN_USE_DIRECT_STORAGE_URLS=true
CDN_SERIALIZE_OPTIMIZATION_JOBS=true
CDN_OPTIMIZATION_OVERLAP_LOCK_SECONDS=14400
CDN_ADMIN_SOURCES_POLLING_INTERVAL=15s
CDN_ADMIN_QUEUE_STATS_POLLING_INTERVAL=60s
CDN_OPTIMIZATION_DASHBOARD_BATCH_LIMIT=10
CDN_API_TOKEN_TOUCH_INTERVAL_SECONDS=300
CDN_INGEST_SECRET=
PORTAL_FETCH_PROXY_URL=https://portal.naraboxtv.com/api/cdn/fetch-and-push
PORTAL_FETCH_PROXY_TOKEN=
PORTAL_WORKER_SYNC_URL=https://portal.naraboxtv.com/api/v1/worker/sync
PORTAL_WORKER_API_TOKEN=
TELEBOT_API_URL=https://teletyde.nara24fm.com
TELEBOT_API_TOKEN=
TELEBOT_TIMEOUT=30
CDN_PYTHON_WORKER_ENABLED=false
CDN_PYTHON_WORKER_QUEUE_URL=
CDN_PYTHON_WORKER_AUTH_TOKEN=
# Laravel worker (naraboxtvworker): when enabled, optimization is sent to the worker instead of local queue.
# Worker URL: e.g. http://wwwogwgw80cwo4g4skw8oggg.157.173.104.218.sslip.io or https://worker.naraboxtv.com
CDN_LARAVEL_WORKER_ENABLED=false
CDN_LARAVEL_WORKER_API_URL=
CDN_LARAVEL_WORKER_API_TOKEN=
# Artifact fetch: connect timeout (seconds), total timeout (seconds). Increase if worker is slow or ZIP is large.
CDN_WORKER_ARTIFACT_CONNECT_TIMEOUT=60
CDN_WORKER_ARTIFACT_FETCH_TIMEOUT=600
FFMPEG_BIN=/usr/bin/ffmpeg
FFPROBE_BIN=/usr/bin/ffprobe
CDN_FFMPEG_BINARY="${FFMPEG_BIN}"
CDN_FFPROBE_BINARY="${FFPROBE_BIN}"
# SAFETY: Set to true only when you explicitly want original MP4s deleted after compression.
# Defaults to false to prevent accidental data loss. Do not enable without verified backups.
CDN_COMPRESS_DELETE_ORIGINAL=false
CDN_COMPRESS_VIDEO_CODEC=libx264
CDN_COMPRESS_AUDIO_CODEC=aac
CDN_COMPRESS_AUDIO_BITRATE=128k
CDN_COMPRESS_CRF=23
CDN_COMPRESS_PRESET=medium
# 0 disables max-height capping; set e.g. 1080 to cap very large uploads.
CDN_COMPRESS_MAX_HEIGHT=0
# false = copy-only faststart for MP4 (no re-encode). true = transcode with libx264.
CDN_COMPRESS_BEFORE_PLAYBACK=false
CDN_ENABLE_HLS=true
CDN_HLS_PROFILES=480
# Seconds to wait between HLS variant encodes (reduces "Resource temporarily unavailable" on busy servers).
CDN_HLS_VARIANT_DELAY_SECONDS=2
MAX_UPLOAD_MB=2048
ALLOWED_VIDEO_EXTENSIONS=mp4,mkv,webm,avi,mov,m4v

NBX_ENGINE_ENABLED=true
NBX_ENGINE_PUBLIC_URL=https://nbx.naraboxtv.com
NBX_ENGINE_API_KEY=
NBX_ENGINE_WEBHOOK_SECRET=
NBX_WEBHOOK_QUEUE=nbx-webhook
NBX_WEBHOOK_RETRY_TIMES=3
NBX_WEBHOOK_RETRY_SLEEP_MS=1500
NBX_WEBHOOK_TIMEOUT=20
NBX_DEFAULT_STORAGE=contabo
NBX_WORK_STORAGE=public
NBX_ALLOW_LOCAL_STORAGE=true
NBX_ALLOW_1080P=false
NBX_DEFAULT_FASTSTART=true
NBX_DEFAULT_HLS_480=true
NBX_DEFAULT_HLS_720=false
NBX_DEFAULT_HLS_1080=false
NBX_KEEP_LOCAL_WORK_FILES=false
NBX_LOCAL_WORK_RETENTION_HOURS=24
NBX_MAX_UPLOAD_SIZE_MB=2048
NBX_UPLOAD_SESSION_TTL_MINUTES=60
NBX_ALLOWED_UPLOAD_EXTENSIONS=mp4,m4v,mov,mkv,webm,avi,mpeg,mpg,ts
NBX_ALLOWED_UPLOAD_MIMES=video/mp4,video/x-m4v,video/quicktime,video/webm,video/x-msvideo,video/x-matroska,video/mpeg,video/mp2t,application/octet-stream
NBX_TEMP_DIR=/var/www/html/storage/app/nbx/tmp
NBX_WORK_DIR=/var/www/html/storage/app/nbx/work
NBX_OUTPUT_DIR=/var/www/html/storage/app/nbx/output
NBX_FETCH_MAX_REDIRECTS=5
NBX_FETCH_CONNECT_TIMEOUT=30
NBX_FETCH_TIMEOUT=7200

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CONTABO_ACCESS_KEY_ID=
CONTABO_SECRET_ACCESS_KEY=
CONTABO_BUCKET=
CONTABO_REGION=usc1
CONTABO_ENDPOINT=https://usc1.contabostorage.com
CONTABO_PUBLIC_URL=
CONTABO_USE_PATH_STYLE_ENDPOINT=true

# Portal-compatible Contabo Object Storage aliases.
# You can copy the portal CONTABO_OBJECT_STORAGE_* block into this app; these map to the same contabo disk.
CONTABO_OBJECT_STORAGE_ENABLED=true
CONTABO_OBJECT_STORAGE_DISK=contabo
CONTABO_OBJECT_STORAGE_ENDPOINT="${CONTABO_ENDPOINT}"
CONTABO_OBJECT_STORAGE_BUCKET="${CONTABO_BUCKET}"
CONTABO_OBJECT_STORAGE_REGION="${CONTABO_REGION}"
CONTABO_OBJECT_STORAGE_ACCESS_KEY="${CONTABO_ACCESS_KEY_ID}"
CONTABO_OBJECT_STORAGE_SECRET_KEY="${CONTABO_SECRET_ACCESS_KEY}"
CONTABO_OBJECT_STORAGE_PUBLIC_URL="${CONTABO_PUBLIC_URL}"
CONTABO_OBJECT_STORAGE_PATH_PREFIX=videos
CONTABO_OBJECT_STORAGE_VISIBILITY=public
CONTABO_OBJECT_STORAGE_USE_PATH_STYLE_ENDPOINT="${CONTABO_USE_PATH_STYLE_ENDPOINT}"

# Optional fallback when S3 keys are blank: NBX can discover Contabo S3 keys via API.
CONTABO_API_BASE_URL=https://api.contabo.com
CONTABO_AUTH_URL=https://auth.contabo.com/auth/realms/contabo/protocol/openid-connect/token
CONTABO_API_CLIENT_ID=
CONTABO_API_CLIENT_SECRET=
CONTABO_API_USERNAME=
CONTABO_API_PASSWORD=
CONTABO_API_USER_ID=
CONTABO_API_OBJECT_STORAGE_ID=
CONTABO_API_TIMEOUT=30
CONTABO_API_CONNECT_TIMEOUT=10

VITE_APP_NAME="${APP_NAME}"
